        {
          "expr": "(label_replace(label_replace((max_over_time(DCGM_FI_PROF_GR_ENGINE_ACTIVE{pod != \"\", namespace!~\"cw-.*\"}[30m]) or max_over_time(DCGM_FI_PROF_GR_ENGINE_ACTIVE{exported_pod != \"\", namespace!~\"cw-.*\"}[30m]) or max_over_time(DCGM_FI_DEV_GPU_UTIL{pod != \"\", namespace!~\"cw-.*\"}[30m]) / 100 or max_over_time(DCGM_FI_DEV_GPU_UTIL{exported_pod != \"\", namespace!~\"cw-.*\"}[30m]) / 100) < 0.01, \"pod\", \"$1\", \"exported_pod\", \"(.+)\"), \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\") * on (pod, namespace) group_left() sum by (pod, namespace) (kube_pod_container_resource_requests{resource=\"nvidia_com_gpu\", namespace!~\"cw-.*\"}))",
